{
  "name": "financial-evidence-lab",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"{apps,packages}/**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "prettier": "^3.3.3",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
