{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fel.dev/schemas/financial-fact/v1",
  "x-fel-version": "1.0.0",
  "title": "NormalizedFinancialFact",
  "description": "Monetary values are decimal strings, never binary floats (spec 11.4).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "concept",
    "value",
    "unit",
    "scale",
    "period",
    "source_span_id",
    "reported_or_derived"
  ],
  "properties": {
    "entity_id": { "type": "string", "format": "uuid" },
    "concept": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "value": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
    "unit": { "type": "string", "minLength": 1 },
    "scale": { "type": "integer" },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["instant", "duration"] },
        "instant": { "type": "string", "format": "date" },
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      }
    },
    "dimensions": { "type": "object", "additionalProperties": { "type": "string" } },
    "source_span_id": { "type": "string", "format": "uuid" },
    "reported_or_derived": { "enum": ["reported", "derived"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
