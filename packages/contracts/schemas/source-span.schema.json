{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fel.dev/schemas/source-span/v1",
  "x-fel-version": "1.0.0",
  "title": "SourceSpan",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_version_id", "section_id", "start_char", "end_char", "text_hash"],
  "properties": {
    "document_version_id": { "type": "string", "format": "uuid" },
    "section_id": { "type": "string", "format": "uuid" },
    "page": { "type": "integer", "minimum": 1 },
    "start_char": { "type": "integer", "minimum": 0 },
    "end_char": { "type": "integer", "minimum": 0 },
    "text_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
