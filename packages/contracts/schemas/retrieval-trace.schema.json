{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fel.dev/schemas/retrieval-trace/v1",
  "x-fel-version": "1.0.0",
  "title": "RetrievalTrace",
  "description": "Immutable Observatory trace for one retrieval run (ADR-0006). plan.$ref query-plan/v1; events.$ref retrieval-event/v1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "query_id",
    "plan",
    "status",
    "lineage",
    "events",
    "candidates",
    "decisions",
    "claims",
    "timings_ms",
    "budget_usage",
    "cost_usd",
    "started_at"
  ],
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "query_id": { "type": "string", "format": "uuid" },
    "status": {
      "enum": [
        "queued",
        "planning",
        "retrieving",
        "fusing",
        "generating",
        "verifying",
        "succeeded",
        "abstained",
        "failed",
        "cancelled"
      ]
    },
    "plan": { "$ref": "https://contracts.fel.dev/schemas/query-plan/v1" },
    "parent_run_id": { "type": ["string", "null"], "format": "uuid" },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_version_id",
        "index_version_id",
        "planner_version",
        "config_hash",
        "embedding_provider",
        "embedding_model"
      ],
      "properties": {
        "corpus_version_id": { "type": "string", "format": "uuid" },
        "index_version_id": { "type": "string", "format": "uuid" },
        "planner_version": { "type": "string" },
        "config_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "embedding_provider": { "type": "string" },
        "embedding_model": { "type": "string" },
        "generation_provider": { "type": ["string", "null"] },
        "generation_model": { "type": ["string", "null"] }
      }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "https://contracts.fel.dev/schemas/retrieval-event/v1" }
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/retrievalClaim" }
    },
    "timings_ms": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "budget_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context_items", "context_tokens", "input_tokens", "output_tokens"],
      "properties": {
        "context_items": { "type": "integer", "minimum": 0 },
        "context_tokens": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "cost_usd": { "type": "string", "pattern": "^\\d+(\\.\\d{1,6})?$" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "$defs": {
    "candidateContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "variant_index",
        "lane_rank",
        "raw_score",
        "rrf_contribution",
        "timing_ms"
      ],
      "properties": {
        "lane": { "enum": ["dense", "lexical", "facts", "tables"] },
        "variant_index": { "type": "integer", "minimum": 0, "maximum": 3 },
        "lane_rank": { "type": "integer", "minimum": 1 },
        "raw_score": { "type": "string" },
        "normalized_score": { "type": ["string", "null"] },
        "rrf_contribution": { "type": "string" },
        "timing_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "kind",
        "contributions",
        "fused_score",
        "accepted",
        "source_span_id",
        "document_version_id",
        "published_at"
      ],
      "properties": {
        "item_id": { "type": "string", "format": "uuid" },
        "kind": { "enum": ["passage", "table_row", "fact"] },
        "contributions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/candidateContribution" }
        },
        "fused_score": { "type": "string" },
        "fused_rank": { "type": ["integer", "null"] },
        "rerank_score": { "type": ["string", "null"] },
        "rerank_rank": { "type": ["integer", "null"] },
        "accepted": { "type": "boolean" },
        "rejection_code": { "type": ["string", "null"] },
        "decision_detail": { "type": "object" },
        "source_span_id": { "type": "string", "format": "uuid" },
        "document_version_id": { "type": "string", "format": "uuid" },
        "published_at": { "type": "string", "format": "date-time" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "code", "item_ids", "occurred_at"],
      "properties": {
        "stage": {
          "enum": ["filter", "dedupe", "fusion", "rerank", "context", "verification", "abstention"]
        },
        "code": { "type": "string" },
        "item_ids": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        },
        "detail": { "type": "object" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "retrievalCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "source_span_id", "status", "numeric_checks"],
      "properties": {
        "item_id": { "type": "string", "format": "uuid" },
        "source_span_id": { "type": "string", "format": "uuid" },
        "status": { "enum": ["entailed", "partial", "contradictory", "irrelevant"] },
        "numeric_checks": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "retrievalClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "status", "citations"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "text": { "type": "string" },
        "status": {
          "enum": ["supported", "partially_supported", "contradicted", "derived", "unsupported"]
        },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/retrievalCitation" }
        }
      }
    }
  }
}
