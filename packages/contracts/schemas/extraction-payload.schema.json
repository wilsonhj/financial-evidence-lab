{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fel.dev/schemas/extraction-payload/v1",
  "title": "ExtractionPayload",
  "oneOf": [
    {
      "$ref": "#/$defs/kpi"
    },
    {
      "$ref": "#/$defs/guidancePoint"
    },
    {
      "$ref": "#/$defs/guidanceRange"
    },
    {
      "$ref": "#/$defs/guidanceFloor"
    },
    {
      "$ref": "#/$defs/guidanceCeiling"
    },
    {
      "$ref": "#/$defs/guidanceQualitative"
    },
    {
      "$ref": "#/$defs/revenueDriver"
    }
  ],
  "$defs": {
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["instant", "duration", "trailing_window", "forecast"]
        },
        "instant": {
          "type": "string",
          "format": "date"
        },
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": "string",
          "format": "date"
        },
        "fiscal_period": {
          "type": ["string", "null"]
        }
      }
    },
    "numericFields": {
      "type": "object",
      "required": ["unit", "scale", "sign"],
      "properties": {
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{3}$"
        },
        "scale": {
          "type": "integer"
        },
        "sign": {
          "enum": ["positive", "negative", "zero"]
        }
      }
    },
    "commonProperties": {
      "schema_version": {
        "const": "extraction-payload/v1"
      },
      "entity_id": {
        "type": "string",
        "format": "uuid"
      },
      "issuer_label": {
        "type": "string",
        "minLength": 1
      },
      "metric_id": {
        "type": "string",
        "minLength": 1
      },
      "raw_value": {
        "type": "string"
      },
      "period": {
        "$ref": "#/$defs/period"
      },
      "dimensions": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "definition": {
        "type": ["string", "null"]
      },
      "qualifiers": {
        "type": "object",
        "additionalProperties": true
      },
      "reported_or_derived": {
        "enum": ["reported", "derived", "management_assertion"]
      }
    },
    "kpi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "entity_id",
        "issuer_label",
        "metric_id",
        "raw_value",
        "value",
        "unit",
        "scale",
        "sign",
        "period",
        "dimensions",
        "qualifiers",
        "reported_or_derived"
      ],
      "properties": {
        "schema_version": {
          "const": "extraction-payload/v1"
        },
        "kind": {
          "const": "kpi"
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        },
        "issuer_label": {
          "type": "string",
          "minLength": 1
        },
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "raw_value": {
          "type": "string"
        },
        "value": {
          "type": "string",
          "pattern": "^-?\\d+(\\.\\d+)?$"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{3}$"
        },
        "scale": {
          "type": "integer"
        },
        "sign": {
          "enum": ["positive", "negative", "zero"]
        },
        "period": {
          "$ref": "#/$defs/period"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "definition": {
          "type": ["string", "null"]
        },
        "qualifiers": {
          "type": "object",
          "additionalProperties": true
        },
        "reported_or_derived": {
          "enum": ["reported", "derived"]
        }
      }
    },
    "guidanceBase": {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": "extraction-payload/v1"
        },
        "kind": {
          "const": "guidance"
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        },
        "issuer_label": {
          "type": "string",
          "minLength": 1
        },
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "raw_value": {
          "type": "string"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{3}$"
        },
        "scale": {
          "type": "integer"
        },
        "sign": {
          "enum": ["positive", "negative", "zero"]
        },
        "period": {
          "$ref": "#/$defs/period"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "definition": {
          "type": ["string", "null"]
        },
        "qualifiers": {
          "type": "object",
          "additionalProperties": true
        },
        "reported_or_derived": {
          "const": "management_assertion"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "entity_id",
        "issuer_label",
        "metric_id",
        "raw_value",
        "shape",
        "period",
        "dimensions",
        "qualifiers",
        "reported_or_derived"
      ]
    },
    "guidancePoint": {
      "allOf": [
        {
          "$ref": "#/$defs/guidanceBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "unit", "scale", "sign"],
          "properties": {
            "schema_version": {},
            "kind": {},
            "entity_id": {},
            "issuer_label": {},
            "metric_id": {},
            "raw_value": {},
            "shape": {
              "const": "point"
            },
            "value": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d+)?$"
            },
            "unit": {},
            "currency": {},
            "scale": {},
            "sign": {},
            "period": {},
            "dimensions": {},
            "definition": {},
            "qualifiers": {},
            "reported_or_derived": {}
          }
        }
      ]
    },
    "guidanceRange": {
      "allOf": [
        {
          "$ref": "#/$defs/guidanceBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "high", "unit", "scale", "sign"],
          "properties": {
            "schema_version": {},
            "kind": {},
            "entity_id": {},
            "issuer_label": {},
            "metric_id": {},
            "raw_value": {},
            "shape": {
              "const": "range"
            },
            "low": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d+)?$"
            },
            "high": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d+)?$"
            },
            "unit": {},
            "currency": {},
            "scale": {},
            "sign": {},
            "period": {},
            "dimensions": {},
            "definition": {},
            "qualifiers": {},
            "reported_or_derived": {}
          }
        }
      ]
    },
    "guidanceFloor": {
      "allOf": [
        {
          "$ref": "#/$defs/guidanceBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "unit", "scale", "sign"],
          "properties": {
            "schema_version": {},
            "kind": {},
            "entity_id": {},
            "issuer_label": {},
            "metric_id": {},
            "raw_value": {},
            "shape": {
              "const": "floor"
            },
            "low": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d+)?$"
            },
            "unit": {},
            "currency": {},
            "scale": {},
            "sign": {},
            "period": {},
            "dimensions": {},
            "definition": {},
            "qualifiers": {},
            "reported_or_derived": {}
          }
        }
      ]
    },
    "guidanceCeiling": {
      "allOf": [
        {
          "$ref": "#/$defs/guidanceBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["high", "unit", "scale", "sign"],
          "properties": {
            "schema_version": {},
            "kind": {},
            "entity_id": {},
            "issuer_label": {},
            "metric_id": {},
            "raw_value": {},
            "shape": {
              "const": "ceiling"
            },
            "high": {
              "type": "string",
              "pattern": "^-?\\d+(\\.\\d+)?$"
            },
            "unit": {},
            "currency": {},
            "scale": {},
            "sign": {},
            "period": {},
            "dimensions": {},
            "definition": {},
            "qualifiers": {},
            "reported_or_derived": {}
          }
        }
      ]
    },
    "guidanceQualitative": {
      "allOf": [
        {
          "$ref": "#/$defs/guidanceBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "schema_version": {},
            "kind": {},
            "entity_id": {},
            "issuer_label": {},
            "metric_id": {},
            "raw_value": {},
            "shape": {
              "const": "qualitative"
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "period": {},
            "dimensions": {},
            "definition": {},
            "qualifiers": {},
            "reported_or_derived": {}
          }
        }
      ]
    },
    "revenueDriver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "entity_id",
        "issuer_label",
        "metric_id",
        "raw_value",
        "category",
        "description",
        "direction",
        "target_metric_ids",
        "period",
        "dimensions",
        "qualifiers",
        "reported_or_derived"
      ],
      "properties": {
        "schema_version": {
          "const": "extraction-payload/v1"
        },
        "kind": {
          "const": "revenue_driver"
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        },
        "issuer_label": {
          "type": "string",
          "minLength": 1
        },
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "raw_value": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "price",
            "volume",
            "mix",
            "acquisition",
            "retention",
            "usage",
            "seats",
            "fx",
            "services",
            "cost",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": ["positive", "negative", "mixed", "unknown"]
        },
        "target_metric_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "period": {
          "$ref": "#/$defs/period"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "definition": {
          "type": ["string", "null"]
        },
        "qualifiers": {
          "type": "object",
          "additionalProperties": true
        },
        "reported_or_derived": {
          "const": "management_assertion"
        }
      }
    }
  },
  "x-fel-version": "1.0.0"
}
