{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fel.dev/schemas/claim/v1",
  "x-fel-version": "1.0.0",
  "title": "Claim",
  "description": "Closed status set (spec 11.3). Only supported/derived may render as factual conclusions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "text", "status"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "text": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["supported", "partially_supported", "contradicted", "derived", "unsupported"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
