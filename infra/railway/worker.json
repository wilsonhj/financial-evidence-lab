{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install -r requirements-dev.txt && pip install ./packages/providers ./workers"
  },
  "deploy": {
    "startCommand": "python -m fel_workers run",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
